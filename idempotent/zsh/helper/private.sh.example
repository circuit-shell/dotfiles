# Create a copy of the file and rename it private.sh, it will be sourced by the
# main zshrc-file, Usefull for private or particular configurations

# flutter
export PATH="$PATH:$HOME/development/flutter/bin"

# postgreSQL
export PATH="/usr/local/opt/postgresql@16/bin:$PATH"zshconfigzshconfig
export PATH="/usr/local/opt/libpq/bin:$PATH"

# python
export PATH="/Library/Frameworks/Python.framework/Versions/3.x/bin:$PATH"
command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
export PYENV_ROOT="$HOME/.pyenv"
eval "$(pyenv virtualenv-init -)"

# java
export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home
export ANDROID_HOME=$HOME/Library/Android/sdk && export PATH=$PATH:$ANDROID_HOME/emulator && export PATH=$PATH:$ANDROID_HOME/platform-tools

# volta
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"

# golang
export GOROOT=$(brew --prefix golang)/libexec
export PATH=$PATH:$GOROOT/bin
export PATH=$PATH:$HOME/go/bin

# Function to create a Btrfs snapshot
snaps() {
	if [ -z "$1" ]; then
	echo "❌ Error: No name provided for the snapshot."
	return 1  # Exit with a failure status
	fi

	name="$1_$(date +%Y%m%d_%H%M%S)"
	sudo btrfs subvolume snapshot / "/.snapshots/@_$name"
	echo "✅ Snapshot created: @_$name"
	sudo btrfs subvolume list /.snapshots
}

snaps() {
	if [ -z "$1" ]; then
	    echo "Usage: snap-delete <snapshot-name>"
	    exit 1
	fi
	sudo btrfs subvolume delete "/.snapshots/$1"
	echo "🗑️ Deleted: $1"
}
